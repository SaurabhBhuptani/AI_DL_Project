{
  "pipeline_name": "bigbird_pair_classifier",
  "model_name": "BigBird",
  "backbone": "google/bigbird-roberta-base",
  "max_abs_words": 300,
  "max_concl_words": 300,
  "max_len": 512,
  "seed": 42,
  "batch_size": 4,
  "grad_accum": 4,
  "lr": 2e-05,
  "head_lr": 5e-05,
  "weight_decay": 0.01,
  "epochs": 12,
  "patience": 4,
  "max_grad_norm": 1.0,
  "label_smoothing": 0.01,
  "warmup_ratio": 0.1,
  "dropout": 0.2,
  "num_workers": 2
}